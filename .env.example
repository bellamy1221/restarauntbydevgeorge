# Environment example — booking integrations (optional)

# Public site URL for metadata
NEXT_PUBLIC_SITE_URL=https://vincenzo.example

# Booking provider: none | yandex | restoplace | quickresto | opentable | sevenrooms | custom | telegram | email
BOOKING_PROVIDER=none

# Provider-specific secrets (fill when integrating)
# YANDEX_BOOKING_TOKEN=
# RESTOPLACE_API_KEY=
# QUICKRESTO_API_KEY=
# OPENTABLE_CLIENT_ID=
# OPENTABLE_CLIENT_SECRET=
# SEVENROOMS_API_KEY=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# RESERVATION_EMAIL_TO=hello@vincenzo.example
